# Google Sheets
# Option 1: Service Account (recommended for server use)
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json
# Option 2: OAuth2 (copy from youtube-video-creator project)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

GOOGLE_SHEET_ID=1sLhVM8btTRGYVpv8PSSZviTPiQht7VZc6E2UAioqqSE
GOOGLE_SHEET_NAME=fishing

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# WhatsApp sender — choose provider:
# WHATSAPP_PROVIDER=macrodroid  (default) — MacroDroid webhook, requires Android phone
# WHATSAPP_PROVIDER=webjs       — whatsapp-web.js microservice, no Android required
WHATSAPP_PROVIDER=macrodroid

# Option A: whatsapp-web.js microservice (set WHATSAPP_PROVIDER=webjs)
# Deploy whatsapp-service/ as a separate Railway service, then set these:
WHATSAPP_SERVICE_URL=https://your-whatsapp-service.railway.app
WHATSAPP_API_KEY=changeme

# Option B: MacroDroid webhook (set WHATSAPP_PROVIDER=macrodroid)
MACRODROID_WEBHOOK_URL=https://trigger.macrodroid.com/YOUR_ID/n8n

# Facebook Graph API
FACEBOOK_PAGE_ID=993730403813933
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_token_here
# For token refresh (get from Facebook Developer Console):
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# AliExpress Affiliate API
ALIEXPRESS_APP_KEY=your_app_key_here
ALIEXPRESS_APP_SECRET=your_app_secret_here

# Server
PORT=3000
NODE_ENV=production

# Google OAuth (Login)
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Railway production: https://affheav-production.up.railway.app/auth/google/callback
# Local dev: http://localhost:3000/auth/google/callback
GOOGLE_CALLBACK_URL=https://affheav-production.up.railway.app/auth/google/callback
# Random secret for signing sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-random-secret-here

# PostgreSQL (add via Railway: New Plugin → PostgreSQL — Railway sets this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# User Management
# The Google email that becomes super-admin on first login (bootstrap)
ADMIN_GOOGLE_EMAIL=your@gmail.com
# Public base URL for generating invite links
APP_BASE_URL=https://affheav-production.up.railway.app
