# Google Sheets
# Option 1: Service Account (recommended for server use)
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json
# Option 2: OAuth2 (copy from youtube-video-creator project)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

GOOGLE_SHEET_ID=1sLhVM8btTRGYVpv8PSSZviTPiQht7VZc6E2UAioqqSE
GOOGLE_SHEET_NAME=fishing

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# MacroDroid (WhatsApp sender)
MACRODROID_WEBHOOK_URL=https://trigger.macrodroid.com/YOUR_ID/n8n

# Facebook Graph API
FACEBOOK_PAGE_ID=993730403813933
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_token_here
# For token refresh (get from Facebook Developer Console):
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# AliExpress Affiliate API
ALIEXPRESS_APP_KEY=your_app_key_here
ALIEXPRESS_APP_SECRET=your_app_secret_here

# Server
PORT=3000
NODE_ENV=production

# Google OAuth (Login)
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Railway production: https://affheav-production.up.railway.app/auth/google/callback
# Local dev: http://localhost:3000/auth/google/callback
GOOGLE_CALLBACK_URL=https://affheav-production.up.railway.app/auth/google/callback
# Only this email can log in (leave empty to allow any Google account)
ALLOWED_GOOGLE_EMAIL=your@gmail.com
# Random secret for signing sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-random-secret-here
