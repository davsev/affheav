PORT=3001

# Secret key — include in X-API-Key header on every /send and /groups request
WHATSAPP_API_KEY=changeme

# Session storage path (Railway: /data/wwebjs_auth via volume; local: leave unset)
# DATA_PATH=/data/wwebjs_auth

# Set automatically by Puppeteer image; override only if using a custom Chrome path
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
